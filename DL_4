import pandas as pd
import numpy as np
from sklearn.preprocessing import MinMaxScaler

# Load data
df = pd.read_csv("goog.csv")

# Use only Close price
data = df[['Close']].values

# Normalize data (important for RNN)
scaler = MinMaxScaler(feature_range=(0, 1))
data_scaled = scaler.fit_transform(data)

def create_dataset(data, time_step=10):
    X, y = [], []
    for i in range(len(data) - time_step):
        X.append(data[i:i+time_step])
        y.append(data[i+time_step])
    return np.array(X), np.array(y)

time_step = 10
X, y = create_dataset(data_scaled, time_step)

# Reshape for RNN [samples, time steps, features]
X = X.reshape(X.shape[0], X.shape[1], 1)

from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import SimpleRNN, Dense

model = Sequential()

model.add(SimpleRNN(50, return_sequences=True, input_shape=(time_step, 1)))
model.add(SimpleRNN(50))
model.add(Dense(1))

model.compile(optimizer='adam', loss='mean_squared_error')

model.summary()

model.fit(X, y, epochs=20, batch_size=16, verbose=1)

train_predict = model.predict(X)

# Convert back to original scale
train_predict = scaler.inverse_transform(train_predict)
y_actual = scaler.inverse_transform(y)

import matplotlib.pyplot as plt

plt.plot(y_actual, label="Actual Price")
plt.plot(train_predict, label="Predicted Price")
plt.legend()
plt.show()
