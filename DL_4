import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

from sklearn.preprocessing import MinMaxScaler
from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score

from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense, SimpleRNN

# Load dataset
dataset = pd.read_csv("goog.csv")

# Convert Date column (optional)
dataset['Date'] = pd.to_datetime(dataset['Date'])

# Use Close price
data = dataset[['Close']].values

# Train-test split
train_size = int(len(data) * 0.8)

train_data = data[:train_size]
test_data = data[train_size:]

# Scale data
sc = MinMaxScaler(feature_range=(0,1))
train_scaled = sc.fit_transform(train_data)

# Window size (important for small dataset)
window_size = 20

# Prepare training data
X_train = []
y_train = []

for i in range(window_size, len(train_scaled)):
    X_train.append(train_scaled[i-window_size:i, 0])
    y_train.append(train_scaled[i, 0])

X_train = np.array(X_train)
y_train = np.array(y_train)

# Reshape for RNN
X_train = np.reshape(X_train, (X_train.shape[0],
                              X_train.shape[1],
                              1))

# Build model
model = Sequential()

model.add(SimpleRNN(units=50,
                    activation='tanh',
                    input_shape=(X_train.shape[1], 1)))

model.add(Dense(units=1))

# Compile
model.compile(optimizer='adam',
              loss='mean_squared_error')

# Train
model.fit(X_train,
          y_train,
          epochs=20,
          batch_size=32)

# Prepare test data
inputs = data[train_size - window_size:]
inputs = sc.transform(inputs)

X_test = []

for i in range(window_size, len(inputs)):
    X_test.append(inputs[i-window_size:i, 0])

X_test = np.array(X_test)

# Reshape
X_test = np.reshape(X_test,
                    (X_test.shape[0],
                     X_test.shape[1],
                     1))

# Predict
predicted_stock_price = model.predict(X_test)

# Inverse scaling
predicted_stock_price = sc.inverse_transform(predicted_stock_price)

# Real values
y_test = data[train_size:]
y_test = y_test[:len(predicted_stock_price)]

# =========================
# 📊 METRICS
# =========================

mae = mean_absolute_error(y_test, predicted_stock_price)
mse = mean_squared_error(y_test, predicted_stock_price)
rmse = np.sqrt(mse)
r2 = r2_score(y_test, predicted_stock_price)

print("Model Performance:")
print(f"MAE  : {mae:.4f}")
print(f"MSE  : {mse:.4f}")
print(f"RMSE : {rmse:.4f}")
print(f"R2   : {r2:.4f}")

# Plot
plt.figure(figsize=(10,5))

plt.plot(y_test, color='red', label='Real Price')
plt.plot(predicted_stock_price, color='blue', label='Predicted Price')

plt.title('Google Stock Price Prediction')
plt.xlabel('Time')
plt.ylabel('Stock Price')
plt.legend()

plt.show()
